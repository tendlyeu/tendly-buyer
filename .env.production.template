# Tendly Buyer - Production Environment Variables
# Copy to .env.production and fill in real values

# Read-only Cloud SQL connection (tender data)
USE_GCP_CLOUD_SQL=true
CLOUD_SQL_INSTANCE=scenic-impact-476918-n6:europe-north1:tendly-prod
DB_NAME=tendly_prod
DB_USER=tendly_admin
DB_PASSWORD=<from-gcp-secret-manager>
GOOGLE_APPLICATION_CREDENTIALS_JSON=<service-account-json>

# Local PostgreSQL for buyer data
TENDLY_DB_URL=postgresql://tendly_buyer:<password>@localhost:5432/tendly_buyer

# LLM API keys
GEMINI_API_KEY=<key>
TOGETHER_API_KEY=<key>

# App configuration
SESSION_SECRET=<generate-with: python3 -c "import secrets; print(secrets.token_hex(32))">
PORT=5002
ENVIRONMENT=production
